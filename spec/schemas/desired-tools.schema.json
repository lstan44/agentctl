{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentctl.justrepl.com/schemas/desired-tools.schema.json",
  "title": "agentctl desired tools",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tools"],
  "properties": {
    "schemaVersion": {
      "const": "agentctl.desired-tools/v1alpha1"
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["enabled", "channel", "version"],
        "properties": {
          "enabled": { "type": "boolean" },
          "channel": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
